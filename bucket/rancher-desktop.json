    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/rancher-sandbox/rancher-desktop/releases/download/v1.22.3/Rancher.Desktop.Setup.1.22.3.msi",
            "hash": "sha512:abc82fb069525dca2a3cf02d5eeb37b759b6d7aa131f8d92916618ba92ae3214b08db77d96b892d25fb7c4a679109f124cca141e5f07a2bb7c2b6bb4f5525636"
        }
    },
    "extract_dir": "Rancher Desktop",
